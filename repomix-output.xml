<file path="backend/src/app/api/hospital/poi/route.ts">
import { NextRequest, NextResponse } from "next/server";
import prisma from "@/lib/db";
import jwt from "jsonwebtoken";

const FRONTEND = process.env.NEXT_PUBLIC_FRONTEND_URL || "http://localhost:3001";

function cors(res: NextResponse) {
  res.headers.set("Access-Control-Allow-Origin", FRONTEND);
  res.headers.set("Access-Control-Allow-Credentials", "true");
  res.headers.set("Access-Control-Allow-Headers", "Content-Type, Authorization");
  res.headers.set("Access-Control-Allow-Methods", "POST, DELETE, OPTIONS");
  return res;
}

export async function OPTIONS() {
  return cors(new NextResponse(null, { status: 204 }));
}

// Helper to get token from multiple sources
function getToken(req: NextRequest) {
  // 1. Check Cookie (Web)
  const cookieToken = req.cookies.get("auth-token")?.value;
  if (cookieToken) return cookieToken;

  // 2. Check Authorization Header (Mobile)
  const authHeader = req.headers.get("Authorization");
  if (authHeader?.startsWith("Bearer ")) {
    return authHeader.split(" ")[1];
  }

  return null;
}

export async function POST(req: NextRequest) {
  const token = getToken(req);

  try {
    if (!token) return cors(NextResponse.json({ error: "Unauthorized: Token Missing" }, { status: 401 }));

    let payload: any;
    try {
      payload = jwt.verify(token, process.env.JWT_SECRET!);
    } catch (err) {
      return cors(NextResponse.json({ error: "Invalid token" }, { status: 401 }));
    }

    const { mapId, action, poiData, graphData } = await req.json();

    if (!mapId) return cors(NextResponse.json({ error: "mapId is required" }, { status: 400 }));

    if (action === "IDENTIFY_AUTO") {
      const nodes = graphData?.nodes || [];
      const autoPois = nodes
        .filter((node: any) => node.type === 'junction' || (node.connections && node.connections > 3))
        .map((node: any) => ({
          name: `Auto-Room-${Math.floor(1000 + Math.random() * 9000)}`,
          type: "ROOM",
          x: node.x,
          y: node.y,
          mapId
        }));
      
      const created = await Promise.all(autoPois.map(p => prisma.pOI.create({ data: p })));
      return cors(NextResponse.json(created, { status: 201 }));
    }

    if (action === "CREATE") {
      const poi = await prisma.pOI.create({ 
        data: { 
          name: poiData.name,
          type: poiData.type,
          x: parseFloat(poiData.x),
          y: parseFloat(poiData.y),
          mapId 
        } 
      });
      return cors(NextResponse.json(poi, { status: 201 }));
    }

    return cors(NextResponse.json({ error: "Invalid action" }, { status: 400 }));
  } catch (error: any) {
    console.error("POI POST Error:", error);
    return cors(NextResponse.json({ error: "Server Error" }, { status: 500 }));
  }
}

export async function DELETE(req: NextRequest) {
  const token = getToken(req);
  if (!token) return cors(NextResponse.json({ error: "Unauthorized" }, { status: 401 }));

  try {
    const { id } = await req.json();
    if (!id) return cors(NextResponse.json({ error: "POI ID required" }, { status: 400 }));

    await prisma.pOI.delete({ where: { id } });
    return cors(NextResponse.json({ message: "POI Deleted" }, { status: 200 }));
  } catch (error: any) {
    return cors(NextResponse.json({ error: "Delete failed" }, { status: 500 }));
  }
}
