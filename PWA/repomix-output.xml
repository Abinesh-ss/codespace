@tailwind base;
@tailwind components;
@tailwind utilities;

/* REQUIRED FOR FULL-SCREEN APPS */
html,
body {
  width: 100%;
  height: 100%;
  margin: 0;
  padding: 0;
}

/* APP DEFAULTS */
body {
  background-color: #020617; /* slate-950 */
  color: #f8fafc;           /* slate-50 */
  overflow: hidden;         /* navigation apps must lock scroll */
  font-feature-settings: "rlig" 1, "calt" 1;
}

/* OPTIONAL – if you want theme variables later */
:root {
  --app-bg: 2 6 23;
  --app-fg: 248 250 252;
}

/* UTILITIES */
@layer utilities {
  .animate-scan {
    animation: scan 2s linear infinite;
  }

  @keyframes scan {
    0% {
      transform: translateY(-110px);
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
    100% {
      transform: translateY(110px);
      opacity: 0;
    }
  }

  .bg-radial-gradient {
    background: radial-gradient(
      circle,
      transparent 30%,
      rgba(2, 6, 23, 0.9) 100%
    );
  }
}
