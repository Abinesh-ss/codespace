type POI = {
  id: string;
  x: number;
  y: number;
};

export default function EditorPage() {
  const router = useRouter();
  const [pois, setPois] = useState<POI[]>([]);
  const [dragId, setDragId] = useState<string | null>(null);

  useEffect(() => {
    fetch("/api/maps/latest", { credentials: "include" })
      .then((r) => r.json())
      .then((d) => setPois(d.graphData.nodes));
  }, []);

  const save = async () => {
    await fetch("/api/maps/update", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ nodes: pois }),
      credentials: "include",
    });

    router.push("/qr");
  };

  return (
    <div className="min-h-screen p-6 bg-gray-50 space-y-6">
      <h1 className="text-3xl font-bold">Adjust Navigation Points</h1>

      <div className="relative bg-white border rounded h-[600px]">
        {pois.map((p) => (
          <div
            key={p.id}
            onMouseDown={() => setDragId(p.id)}
            onMouseUp={() => setDragId(null)}
            onMouseMove={(e) => {
              if (dragId === p.id) {
                setPois(prev =>
                  prev.map(x =>
                    x.id === p.id ? { ...x, x: e.nativeEvent.offsetX, y: e.nativeEvent.offsetY } : x
                  )
                );
              }
            }}
            style={{ left: p.x, top: p.y }}
            className="absolute w-4 h-4 bg-indigo-600 rounded-full cursor-move"
          />
        ))}
      </div>

      <button onClick={save} className="px-6 py-3 bg-indigo-600 text-white rounded-lg flex gap-2">
        <Save /> Save & Generate QR
      </button>
    </div>
  );
}
