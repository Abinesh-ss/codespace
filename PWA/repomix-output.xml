<file path="components/FloorDetector.tsx">
"use client";

import { useEffect, useState } from "react";

interface FloorDetectorProps {
  onFloor: (floor: number) => void;
  defaultFloor?: number;
}

export default function FloorDetector({ onFloor, defaultFloor = 0 }: FloorDetectorProps) {
  useEffect(() => {
    const saved = localStorage.getItem("floor");
    
    // Validate that 'saved' is a legitimate number, otherwise use defaultFloor
    const numericFloor = (saved && !isNaN(Number(saved))) 
      ? Number(saved) 
      : defaultFloor;

    localStorage.setItem("floor", numericFloor.toString());
    onFloor(numericFloor);
  }, [defaultFloor, onFloor]);

  return null; 
}
