<file path="app/upload/page.tsx">
"use client";

import { useRef, useState } from "react";
import { Upload, Save } from "lucide-react";
import { useRouter } from "next/navigation";

interface NodePoint {
  id: string;
  x: number;
  y: number;
}

export default function MapUploadPage() {
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const router = useRouter();

  const [image, setImage] = useState<HTMLImageElement | null>(null);
  const [nodes, setNodes] = useState<NodePoint[]>([]);

  const handleImageUpload = (file: File) => {
    const img = new Image();
    img.onload = () => {
      setImage(img);

      // AUTO-GENERATE POIs
      const autoNodes: NodePoint[] = [
        { id: crypto.randomUUID(), x: img.width * 0.2, y: img.height * 0.2 },
        { id: crypto.randomUUID(), x: img.width * 0.5, y: img.height * 0.4 },
        { id: crypto.randomUUID(), x: img.width * 0.8, y: img.height * 0.6 },
      ];

      setNodes(autoNodes);
      draw(img, autoNodes);
    };
    img.src = URL.createObjectURL(file);
  };

  const draw = (img: HTMLImageElement, nodes: NodePoint[]) => {
    const canvas = canvasRef.current!;
    const ctx = canvas.getContext("2d")!;
    canvas.width = img.width;
    canvas.height = img.height;

    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.drawImage(img, 0, 0);

    nodes.forEach((n) => {
      ctx.beginPath();
      ctx.arc(n.x, n.y, 6, 0, Math.PI * 2);
      ctx.fillStyle = "#4F46E5";
      ctx.fill();
    });
  };

  const saveMap = async () => {
    await fetch("/api/maps/save", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        graphData: { nodes, edges: [] },
      }),
      credentials: "include",
    });

    router.push("/editor"); // redirect to editor
  };

  return (
    <div className="min-h-screen p-6 bg-gray-50 space-y-6">
      <h1 className="text-3xl font-bold">Upload Floor Map</h1>

      <label className="flex gap-3 px-4 py-3 bg-white border rounded-lg cursor-pointer w-fit">
        <Upload className="w-5 h-5 text-indigo-600" />
        Upload Image
        <input hidden type="file" accept="image/*" onChange={(e) => e.target.files && handleImageUpload(e.target.files[0])} />
      </label>

      {image && (
        <canvas ref={canvasRef} className="border rounded bg-white" />
      )}

      {nodes.length > 0 && (
        <button onClick={saveMap} className="px-5 py-3 bg-indigo-600 text-white rounded-lg flex gap-2">
          <Save /> Continue to Editor
        </button>
      )}
    </div>
  );
}
