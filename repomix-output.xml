import { useState, useEffect } from "react";
import QRAnchorScanner from "@/components/QRAnchorScanner";
import MapOverlay from "@/components/MapOverlay";
import NavigationSteps from "@/components/NavigationSteps";
import { Compass, Map as MapIcon, Navigation, Search, X } from "lucide-react";

export default function NavigatePage() {
  // Navigation State
  const [scannedNodeId, setScannedNodeId] = useState<string | undefined>();
  const [targetNodeId, setTargetNodeId] = useState<string | undefined>();
  const [floorId, setFloorId] = useState<string | undefined>();
  const [floor, setFloor] = useState(0);
  const [currentLocation, setCurrentLocation] = useState("Scan a QR to Begin");

  // Search UI State
  const [searchQuery, setSearchQuery] = useState("");
  const [isSearching, setIsSearching] = useState(false);
  const [viewMode, setViewMode] = useState<"camera" | "map">("camera");

  // Placeholder for destination list - in a real app, you'd fetch this from /api/pois
  const destinations = [
    { id: "RECEPTION_DESK", label: "Main Reception", floor: 0 },
    { id: "PHARMACY_01", label: "Pharmacy", floor: 0 },
    { id: "EMERGENCY_ROOM", label: "Emergency Room", floor: 0 },
    { id: "LAB_CARDIOLOGY", label: "Cardiology Lab", floor: 1 },
  ];

  const filteredDestinations = destinations.filter(d => 
    d.label.toLowerCase().includes(searchQuery.toLowerCase())
  );

  const handleQRDetect = (data: any) => {
    try {
      let nodeId = "";
      if (typeof data.id === "string" && data.id.startsWith("http")) {
        const url = new URL(data.id);
        nodeId = url.pathname.split("/").pop() || "";
        const fId = url.searchParams.get("mapId");
        if (fId) setFloorId(fId);
      } else {
        nodeId = data.id;
        if (data.floorId) setFloorId(data.floorId);
      }

      if (nodeId && nodeId !== scannedNodeId) {
        setScannedNodeId(nodeId);
        setFloor(data.floor || 0);
        setCurrentLocation(data.label || `Fixed: ${nodeId}`);
        if (window.navigator.vibrate) window.navigator.vibrate(100);
      }
    } catch (err) {
      console.error("QR Error:", err);
    }
  };

  return (
    <main className="fixed inset-0 bg-slate-950 flex flex-col font-sans text-slate-50">
      {/* --- SEARCH OVERLAY --- */}
      {isSearching && (
        <div className="absolute inset-0 z-50 bg-slate-900 flex flex-col p-6 animate-in fade-in slide-in-from-bottom-4 duration-200">
          <div className="flex items-center gap-4 mb-6">
            <div className="flex-1 relative">
              <Search className="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500" size={18} />
              <input 
                autoFocus
                className="w-full bg-slate-800 border border-slate-700 rounded-xl py-3 pl-10 pr-4 focus:outline-none focus:ring-2 focus:ring-blue-500"
                placeholder="Where are you going?"
                value={searchQuery}
                onChange={(e) => setSearchQuery(e.target.value)}
              />
            </div>
            <button onClick={() => setIsSearching(false)} className="p-2 bg-slate-800 rounded-full">
              <X size={20} />
            </button>
          </div>
          
          <div className="flex-1 overflow-y-auto space-y-2">
            <p className="text-xs font-bold text-slate-500 uppercase tracking-widest mb-4">Quick Locations</p>
            {filteredDestinations.map(dest => (
              <button 
                key={dest.id}
                onClick={() => {
                  setTargetNodeId(dest.id);
                  setIsSearching(false);
                  setSearchQuery("");
                }}
                className={`w-full flex justify-between items-center p-4 rounded-xl border transition-all ${
                  targetNodeId === dest.id ? "bg-blue-600 border-blue-400" : "bg-slate-800 border-slate-700"
                }`}
              >
                <div className="text-left">
                  <p className="font-bold">{dest.label}</p>
                  <p className="text-xs opacity-60 text-slate-300">Floor {dest.floor}</p>
                </div>
                <Navigation size={18} />
              </button>
            ))}
          </div>
        </div>
      )}

      {/* --- HEADER --- */}
      <header className="p-4 bg-slate-900/80 backdrop-blur-md border-b border-slate-800 flex justify-between items-center">
        <div>
          <h1 className="text-[20px] font-bold tracking-tight leading-none mb-1">
            HospiNav <span className="text-blue-500">PRO</span>
          </h1>
          <p className="text-xs text-slate-400 flex items-center gap-1">
            <Compass size={12} className="text-blue-400" /> {currentLocation}
          </p>
        </div>
        <button 
          onClick={() => setIsSearching(true)}
          className="bg-slate-800 p-2 rounded-full border border-slate-700"
        >
          <Search size={20} className="text-blue-400" />
        </button>
      </header>

      {/* --- MAIN VIEWPORT --- */}
      <div className="relative flex-1 overflow-hidden">
        {viewMode === "camera" ? (
          <div className="w-full h-full">
             <QRAnchorScanner onDetect={handleQRDetect} />
             <div className="absolute inset-0 border-[40px] border-slate-950/40 pointer-events-none flex items-center justify-center">
                <div className="w-64 h-64 border-2 border-blue-400/50 rounded-2xl shadow-[0_0_20px_rgba(59,130,246,0.3)]" />
             </div>
          </div>
        ) : (
          <div className="w-full h-full p-4 bg-slate-800">
            <MapOverlay floor={floor} />
          </div>
        )}

        <div className="absolute top-4 right-4 flex flex-col gap-2">
          <button 
            onClick={() => setViewMode(viewMode === "camera" ? "map" : "camera")}
            className="p-3 bg-white text-slate-900 rounded-full shadow-xl"
          >
            {viewMode === "camera" ? <MapIcon size={24} /> : <Navigation size={24} />}
          </button>
        </div>
      </div>

      {/* --- BOTTOM DRAWER --- */}
      <section className="bg-white text-slate-900 rounded-t-[32px] p-6 shadow-2xl">
        <div className="w-12 h-1.5 bg-slate-200 rounded-full mx-auto mb-4" />
        <div className="flex justify-between items-end mb-4">
          <p className="text-xs font-bold text-slate-400 uppercase tracking-widest">Active Route</p>
          {targetNodeId && (
            <p className="text-sm font-bold text-blue-600">to {destinations.find(d => d.id === targetNodeId)?.label}</p>
          )}
        </div>
        <NavigationSteps 
          startNodeId={scannedNodeId} 
          endNodeId={targetNodeId} 
          floorId={floorId}
        />
      </section>
    </main>
  );
}
</file>

