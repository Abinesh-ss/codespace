"use client";

import { useState, useEffect, useCallback, useRef } from "react";
import {
  Search,
  RotateCcw,
  X,
  Camera,
  Volume2,
  VolumeX
} from "lucide-react";

import QRAnchorScanner from "@/components/QRAnchorScanner";
import NavigationSteps from "@/components/NavigationSteps";
import Compass from "@/components/Compass";
import FloorDetector from "@/components/FloorDetector";
import MapOverlay from "@/components/MapOverlay";

interface POI {
  id: string;
  name: string;
  qrId: string;
  nodeId: string;
  floorId: string;
  x?: number;
  y?: number;
}

export default function NavigatePage() {
  const [showScanner, setShowScanner] = useState(false);
  const [searchQuery, setSearchQuery] = useState("");
  const [isMuted, setIsMuted] = useState(false);
  const [rotation, setRotation] = useState(0);

  const [hospitalId, setHospitalId] = useState<string | null>(null);
  const [currentLocation, setCurrentLocation] = useState("Scan QR to Begin");

  const [scannedNode, setScannedNode] = useState<{ id: string; x: number; y: number } | null>(null);
  const [targetNode, setTargetNode] = useState<{ id: string; x: number; y: number } | null>(null);
  const [pathCoords, setPathCoords] = useState<{ x: number; y: number }[]>([]);

  const [floorId, setFloorId] = useState("0");
  const [poiList, setPoiList] = useState<POI[]>([]);
  const [scanLocked, setScanLocked] = useState(false);

  /* 🔥 NEW: DISTANCE + ETA */
  const [distance, setDistance] = useState(0);
  const [eta, setEta] = useState(0);

  const lastPositionRef = useRef<{ x: number; y: number } | null>(null);

  /* ---------------- VOICE ---------------- */
  const speak = useCallback(
    (text: string) => {
      if (isMuted || typeof window === "undefined") return;
      window.speechSynthesis.cancel();
      const utterance = new SpeechSynthesisUtterance(text);
      utterance.lang = "ta-IN"; // 🔥 Tamil
      window.speechSynthesis.speak(utterance);
    },
    [isMuted]
  );

  /* ---------------- GYROSCOPE ---------------- */
  useEffect(() => {
    const handleOrientation = (e: DeviceOrientationEvent) => {
      if (e.alpha !== null) setRotation(e.alpha);
    };
    window.addEventListener("deviceorientation", handleOrientation);
    return () => window.removeEventListener("deviceorientation", handleOrientation);
  }, []);

  /* ---------------- FETCH HOSPITAL ---------------- */
  useEffect(() => {
    fetch("/api/hospital/active")
      .then((r) => r.json())
      .then((d) => d?.id && setHospitalId(d.id));
  }, []);

  /* ---------------- FETCH POIs ---------------- */
  useEffect(() => {
    if (!hospitalId) return;

    fetch(`/api/hospital/${hospitalId}/locations`)
      .then((r) => r.json())
      .then((d) => {
        if (!d?.locations) return;

        const pois: POI[] = d.locations.flatMap((loc: any) =>
          loc.pois.map((poi: any) => ({
            id: poi.id,
            name: poi.name,
            qrId: poi.qrId,
            nodeId: poi.nodeId,
            floorId: String(poi.floor?.level ?? loc.floor?.level ?? "0"),
            x: poi.x,
            y: poi.y
          }))
        );

        setPoiList(pois);
      });
  }, [hospitalId]);

  /* ---------------- DISTANCE + ETA ---------------- */
  useEffect(() => {
    if (!pathCoords.length) return;

    let total = 0;

    for (let i = 1; i < pathCoords.length; i++) {
      total += Math.hypot(
        pathCoords[i].x - pathCoords[i - 1].x,
        pathCoords[i].y - pathCoords[i - 1].y
      );
    }

    setDistance(Math.round(total));

    const timeSec = total / 1.4;
    setEta(Math.ceil(timeSec / 60));
  }, [pathCoords]);

  /* ---------------- RESET ---------------- */
  const handleReset = () => {
    setScannedNode(null);
    setTargetNode(null);
    setPathCoords([]);
    setFloorId("0");
    setDistance(0);
    setEta(0);
  };

  /* ---------------- QR DETECT ---------------- */
const handleQRDetect = async (data: string) => {
  if (scanLocked) return;
  setScanLocked(true);

  try {
    console.log("📷 QR RAW:", data);

    const qrId = data.includes("/api/scan/")
      ? data.split("/api/scan/")[1]
      : data;

    console.log("🆔 QR ID:", qrId);

    const res = await fetch(`/api/scan/${qrId}`);

    if (!res.ok) {
      const text = await res.text();
      console.error("❌ API ERROR:", text);
      setError("Invalid QR");
      return;
    }

    const result = await res.json();
    console.log("✅ API RESPONSE:", result);

    if (
      !result ||
      !result.nodeId ||
      result.x === undefined ||
      result.y === undefined
    ) {
      console.error("❌ Invalid API data");
      setError("Invalid location data");
      return;
    }

    const newPos = {
      id: result.nodeId,
      x: Number(result.x),
      y: Number(result.y),
    };

    if (isNaN(newPos.x) || isNaN(newPos.y)) {
      console.error("❌ Coordinates NaN");
      setError("Invalid coordinates");
      return;
    }

    setScannedNode(newPos);
    setCurrentLocation(result.locationName || "Unknown");
    setFloorId(result.floorId || "0");
    setShowScanner(false);

    console.log("🎯 LOCATION SET:", newPos);

  } catch (err) {
    console.error("🔥 QR HANDLE ERROR:", err);
    setError("QR failed");
  } finally {
    setTimeout(() => setScanLocked(false), 1500);
  }
};

  /* ---------------- SEARCH ---------------- */
  const filteredPOIs = poiList.filter(
    (p) =>
      p.floorId === floorId &&
      p.name.toLowerCase().includes(searchQuery.toLowerCase())
  );

  return (
    <main className="fixed inset-0 bg-slate-950 text-white flex flex-col">

      <FloorDetector onFloor={(f) => setFloorId(String(f))} />

      {/* HEADER */}
      <header className="h-16 flex justify-between items-center px-4 border-b border-white/10">
        <Compass />

        <div className="text-xs text-center">
          <p className="text-blue-500 font-bold">VAZHIKATTI</p>
          {scannedNode && <p>{currentLocation}</p>}
        </div>

        <button onClick={() => setIsMuted(!isMuted)}>
          {isMuted ? <VolumeX /> : <Volume2 />}
        </button>
      </header>

      {/* MAP */}
      <div className="flex-1 relative">
        <MapOverlay
          poiList={poiList.filter((p) => p.floorId === floorId)}
          userPos={scannedNode}
          targetPos={targetNode || undefined}
          path={pathCoords}
          rotation={rotation}
        />

        {/* 🔥 SCAN TO START UI */}
        {!scannedNode && (
          <div className="absolute inset-0 flex flex-col items-center justify-center bg-slate-950 z-30">
            <div className="w-24 h-24 bg-blue-600/10 rounded-full flex items-center justify-center mb-6 animate-pulse">
              <Camera size={42} className="text-blue-500" />
            </div>

            <h2 className="text-lg font-semibold">Start Navigation</h2>

            <button
              onClick={() => setShowScanner(true)}
              className="mt-6 px-6 py-3 bg-blue-600 rounded-xl"
            >
              Scan to Start
            </button>
          </div>
        )}

        {/* CAMERA BUTTON */}
        {scannedNode && (
          <button
            onClick={() => setShowScanner(true)}
            className="absolute top-4 right-4 bg-blue-600 p-3 rounded-full"
          >
            <Camera />
          </button>
        )}
      </div>

      {/* FOOTER */}
      {scannedNode && (
        <footer className="p-4 border-t border-white/10">

          {targetNode && (
            <div className="text-xs text-blue-400 mb-2">
              📏 {distance}m • ⏱️ {eta} min
            </div>
          )}

          {!targetNode ? (
            <>
              <input
                value={searchQuery}
                onChange={(e) => setSearchQuery(e.target.value)}
                placeholder="Search destination..."
                className="w-full p-3 bg-black rounded"
              />

              <div className="mt-2 space-y-2">
                {filteredPOIs.map((poi) => (
                  <button
                    key={poi.id}
                    onClick={() =>
                      setTargetNode({
                        id: poi.nodeId,
                        x: poi.x || 0,
                        y: poi.y || 0
                      })
                    }
                    className="block w-full text-left"
                  >
                    {poi.name}
                  </button>
                ))}
              </div>
            </>
          ) : (
            <NavigationSteps
              startNodeId={scannedNode.id}
              endNodeId={targetNode.id}
              floorId={floorId}
              hospitalId={hospitalId!}
              onStepUpdate={speak}
              onPathUpdate={setPathCoords}
            />
          )}
        </footer>
      )}

      {/* SCANNER */}
      {showScanner && (
        <div className="fixed inset-0 bg-black z-50">
          <QRAnchorScanner onDetect={handleQRDetect} />
          <button
            onClick={() => setShowScanner(false)}
            className="absolute top-10 right-6"
          >
            <X />
          </button>
        </div>
      )}
    </main>
  );
}
</file>

