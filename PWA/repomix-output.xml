<file path="components/LiveLocation.tsx">
"use client";
import { useEffect, useState } from "react";

export default function LiveLocation() {
  const [pos, setPos] = useState<{lat: number, lng: number} | null>(null);

  useEffect(() => {
    if (!navigator.geolocation) return;

    const id = navigator.geolocation.watchPosition(
      p => setPos({ lat: p.coords.latitude, lng: p.coords.longitude }),
      () => {},
      { enableHighAccuracy: true }
    );

    return () => navigator.geolocation.clearWatch(id);
  }, []);

  if (!pos) return <span className="text-xs text-slate-500">GPS...</span>;

  return (
    <span className="text-xs text-slate-400">
      📍 {pos.lat.toFixed(4)}, {pos.lng.toFixed(4)}
    </span>
  );
}
</file>

<file path="components/MapOverlay.tsx">
"use client";

import { useMemo, useEffect, useState } from "react";

interface MapOverlayProps {
  poiList: any[];
  userPos: { x: number; y: number } | null;
  targetPos?: { x: number; y: number };
  path: { x: number; y: number }[];
  rotation: number;
}

export default function MapOverlay({
  poiList,
  userPos,
  targetPos,
  path,
  rotation
}: MapOverlayProps) {

  /* ✅ Find closest point on path */
  const currentIndex = useMemo(() => {
    if (!userPos || path.length === 0) return 0;

    let closestIndex = 0;
    let minDist = Infinity;

    path.forEach((p, i) => {
      const dist = Math.hypot(p.x - userPos.x, p.y - userPos.y);
      if (dist < minDist) {
        minDist = dist;
        closestIndex = i;
      }
    });

    return closestIndex;
  }, [userPos, path]);

  const completedPath = path.slice(0, currentIndex + 1);
  const remainingPath = path.slice(currentIndex);

  /* ---------------------------------- */
  /* ✅ LIVE MOVING ARROW STATE */
  /* ---------------------------------- */
  const [arrowPos, setArrowPos] = useState<{ x: number; y: number }>({ x: 0, y: 0 });
  const [arrowAngle, setArrowAngle] = useState(0);

  useEffect(() => {
    if (path.length < 2) return;

    const p1 = path[currentIndex];
    const p2 = path[currentIndex + 1] || p1;

    // Smooth interpolate
    const midX = (p1.x + p2.x) / 2;
    const midY = (p1.y + p2.y) / 2;

    setArrowPos({ x: midX, y: midY });

    // Calculate direction
    const angle = Math.atan2(p2.y - p1.y, p2.x - p1.x) * (180 / Math.PI);
    setArrowAngle(angle);

  }, [currentIndex, path]);

  return (
    <div className="relative w-full h-full bg-[#020617] overflow-hidden flex items-center justify-center">

      {/* GRID */}
      <div
        className="absolute inset-0 opacity-10"
        style={{
          backgroundImage: "radial-gradient(#3b82f6 0.5px, transparent 0.5px)",
          backgroundSize: "30px 30px"
        }}
      />

      {/* MAP ROTATION */}
      <div
        className="absolute inset-0"
        style={{
          transform: `rotate(${-rotation}deg)`,
          transition: "transform 0.2s linear"
        }}
      >
        <svg
          viewBox="0 0 100 100"
          className="absolute inset-0 w-full h-full p-10"
        >

          {/* COMPLETED PATH */}
          {completedPath.length > 1 && (
            <polyline
              points={completedPath.map((p) => `${p.x},${p.y}`).join(" ")}
              fill="none"
              stroke="#64748b"
              strokeWidth="1.5"
            />
          )}

          {/* REMAINING PATH */}
          {remainingPath.length > 1 && (
            <>
              <polyline
                points={remainingPath.map((p) => `${p.x},${p.y}`).join(" ")}
                fill="none"
                stroke="#3b82f6"
                strokeWidth="4"
                opacity="0.2"
              />
              <polyline
                points={remainingPath.map((p) => `${p.x},${p.y}`).join(" ")}
                fill="none"
                stroke="#3b82f6"
                strokeWidth="2"
              />
            </>
          )}

          {/* 🔥 LIVE MOVING ARROW */}
          {path.length > 1 && (
            <g
              transform={`translate(${arrowPos.x}, ${arrowPos.y}) rotate(${arrowAngle})`}
              style={{ transition: "all 0.3s ease-out" }}
            >
              <path
                d="M-2 -4 L4 0 L-2 4 Z"
                fill="#3b82f6"
              />
            </g>
          )}

          {/* POIs */}
          {poiList?.map((poi) => (
            <g key={poi.id}>
              <circle cx={poi.x} cy={poi.y} r="1.2" fill="#1e293b" stroke="#3b82f6" strokeWidth="0.3" />
              <text x={poi.x} y={poi.y + 4} fontSize="2.5" fill="#64748b" textAnchor="middle">
                {poi.name}
              </text>
            </g>
          ))}

          {/* USER */}
          {userPos && (
            <g transform={`translate(${userPos.x}, ${userPos.y})`}>
              <circle r="6" fill="#3b82f6" className="opacity-20 animate-ping" />
              <circle r="2.2" fill="#3b82f6" />
            </g>
          )}

          {/* DESTINATION */}
          {targetPos && (
            <g transform={`translate(${targetPos.x}, ${targetPos.y})`}>
              <path d="M0 0 L-2 -5 A2 2 0 1 1 2 -5 Z" fill="#ef4444" />
            </g>
          )}
        </svg>
      </div>

      {/* DEBUG */}
      <div className="absolute bottom-4 left-4 text-[8px] text-blue-400/50">
        Step: {currentIndex}
      </div>
    </div>
  );
}
</file>

<file path="components/NavigationSteps.tsx">
"use client";

import { useEffect, useState, useRef } from "react";
import { ChevronRight, Navigation2 } from "lucide-react";

interface Props {
  startNodeId: string;
  endNodeId: string;
  floorId: string;
  hospitalId: string;
  onStepUpdate: (text: string) => void;
  onPathUpdate: (coords: { x: number; y: number }[]) => void;
}

export default function NavigationSteps({
  startNodeId,
  endNodeId,
  floorId,
  hospitalId,
  onStepUpdate,
  onPathUpdate
}: Props) {
  const [steps, setSteps] = useState<string[]>([]);
  const [eta, setEta] = useState<number>(0);
  const [distance, setDistance] = useState<number>(0);
  const [loading, setLoading] = useState(false);

  const lastSpokenRef = useRef("");

  useEffect(() => {
    if (!startNodeId || !endNodeId) return;

    async function getRoute() {
      setLoading(true);

      try {
        const res = await fetch("/api/navigation/shortest-path", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            hospitalId,
            floorId,
            startNodeId,
            endNodeId
          })
        });

        const data = await res.json();

        if (data.path) {
          const cleanPath = data.path.map((p: any) => ({
            x: Number(p.x),
            y: Number(p.y)
          }));

          onPathUpdate(cleanPath);

          /* ✅ DISTANCE */
          const dist = data.distance || 0;
          setDistance(dist);

          /* ✅ ETA (walking ~1.2 m/s) */
          const etaMin = dist > 0 ? Math.round(dist / 70) : 0;
          setEta(etaMin);

          const generatedSteps = [
            "Start moving",
            "Follow the blue path",
            "Destination reached"
          ];

          setSteps(generatedSteps);

          if (generatedSteps[0] !== lastSpokenRef.current) {
            onStepUpdate(generatedSteps[0]);
            lastSpokenRef.current = generatedSteps[0];
          }
        }
      } catch (err) {
        console.error(err);
      } finally {
        setLoading(false);
      }
    }

    getRoute();
  }, [startNodeId, endNodeId, floorId, hospitalId]);

  if (loading) {
    return <div className="text-blue-400 text-xs">Calculating...</div>;
  }

  return (
    <div className="space-y-3">

      {/* ✅ ETA DISPLAY */}
      <div className="text-xs text-green-400 font-bold">
        ⏱️ Reach in {eta || 1} min • 📏 {Math.round(distance)} m
      </div>

      {steps.map((step, i) => (
        <div key={i} className="flex items-center gap-4 bg-white/5 p-4 rounded-xl">
          <Navigation2 size={16} />
          <p>{step}</p>
          <ChevronRight className="ml-auto" size={16} />
        </div>
      ))}
    </div>
  );
}
</file>

<file path="components/QRAnchorScanner.tsx">
"use client";

import { useEffect, useRef, useState } from "react";
import jsQR from "jsqr";
import { CameraOff, RefreshCw } from "lucide-react";

interface Props {
  onDetect: (data: string) => void;
}

export default function QRAnchorScanner({ onDetect }: Props) {
  const videoRef = useRef<HTMLVideoElement>(null);
  const canvasRef = useRef<HTMLCanvasElement | null>(null);
  const lastScanRef = useRef<string | null>(null);
  const rafRef = useRef<number | null>(null);
  const streamRef = useRef<MediaStream | null>(null);

  const [error, setError] = useState<string | null>(null);
  const [retryKey, setRetryKey] = useState(0);

  /* ---------------- SCAN LOOP ---------------- */
  const scan = () => {
    const video = videoRef.current;

    if (video && video.readyState === video.HAVE_ENOUGH_DATA) {
      if (!canvasRef.current) canvasRef.current = document.createElement("canvas");

      const canvas = canvasRef.current;
      canvas.width = video.videoWidth;
      canvas.height = video.videoHeight;

      const ctx = canvas.getContext("2d", { willReadFrequently: true });

      if (ctx) {
        ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

        const img = ctx.getImageData(0, 0, canvas.width, canvas.height);
        const code = jsQR(img.data, img.width, img.height);

        if (code?.data) {
          if (code.data !== lastScanRef.current) {
            console.log("✅ QR DETECTED:", code.data);

            lastScanRef.current = code.data;
            onDetect(code.data);

            /* cooldown */
            setTimeout(() => {
              lastScanRef.current = null;
            }, 2000);
          }
        }
      }
    }

    rafRef.current = requestAnimationFrame(scan);
  };

  /* ---------------- CAMERA ---------------- */
  useEffect(() => {
    let mounted = true;

    const start = async () => {
      try {
        const stream = await navigator.mediaDevices.getUserMedia({
          video: { facingMode: "environment" }
        });

        if (!mounted) {
          stream.getTracks().forEach((t) => t.stop());
          return;
        }

        streamRef.current = stream;

        if (videoRef.current) {
          videoRef.current.srcObject = stream;
          await videoRef.current.play();
          scan();
        }
      } catch (err) {
        console.error(err);
        setError("Camera permission denied");
      }
    };

    start();

    return () => {
      mounted = false;
      streamRef.current?.getTracks().forEach((t) => t.stop());
      if (rafRef.current) cancelAnimationFrame(rafRef.current);
    };
  }, [retryKey]);

  return (
    <div className="relative w-full h-full bg-black flex items-center justify-center">

      {error ? (
        <div className="text-center">
          <CameraOff className="text-red-500 mx-auto mb-4" size={30} />
          <button
            onClick={() => setRetryKey((k) => k + 1)}
            className="bg-blue-600 px-4 py-2 rounded"
          >
            <RefreshCw size={16} /> Retry
          </button>
        </div>
      ) : (
        <>
          <video ref={videoRef} className="w-full h-full object-cover" muted playsInline />

          {/* Scanner UI */}
          <div className="absolute inset-0 flex items-center justify-center">
            <div className="w-72 h-72 border-4 border-blue-500 rounded-3xl animate-pulse" />
          </div>

          <p className="absolute bottom-10 text-xs bg-black/60 px-4 py-2 rounded">
            Scan QR to detect location
          </p>
        </>
      )}
    </div>
  );
}
